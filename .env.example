# ─── Local development ───────────────────────────────────────────────────
# Next.js loads .env.local automatically. Copy this file to .env.local and fill in values.
# Never commit .env.local — it's already in .gitignore.

# Local PostgreSQL (Docker or native):
#   docker run -d --name crm-pg -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=crm -p 5432:5432 postgres:16-alpine
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm"

# Generate a strong secret:  openssl rand -base64 32
JWT_SECRET="change-this-to-a-random-secret"

# ─── Production (Vercel + Supabase) ─────────────────────────────────────
# Set these in Vercel's environment variables dashboard — NEVER in a file.
# Use the Supabase pooler connection (port 6543, pgbouncer=true):
# DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-xx.pooler.supabase.com:6543/postgres?pgbouncer=true"
# JWT_SECRET="<same-secret-used-locally>"
